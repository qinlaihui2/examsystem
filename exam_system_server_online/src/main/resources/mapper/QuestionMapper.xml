<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atguigu.exam.mapper.QuestionMapper">
    <!--
    1.不能选择resultMap,因为是多表查询，赋值的结果有嵌套关系resulrMap自定义结果类型
    2.不能使用分号结尾
    -->
    <resultMap id="questionMap" type="com.atguigu.exam.entity.Question">
        <!--第一层 question的属性-->
        <id column="id" property="id"></id>
        <association property="answer" javaType="com.atguigu.exam.entity.QuestionAnswer">
            <id column="qa_id" property="id" />
            <result column="qa_create_time" property="createTime" />
            <result column="qa_update_time" property="updateTime" />
            <result column="qa_is_deleted" property="isDeleted"/>
        </association>
        <!--
        对多：选项 分布查询，触发第二次查询
        column ->向下传递的列（当前查询中，向下传递的列名）
        select -> 触发的第二次查询mapper的全限定符方法名
        -->
        <collection property="choices" ofType="com.atguigu.exam.entity.QuestionChoice"
                    column="id" select="com.atguigu.exam.mapper.QuestionChoiceMapper.selectListByQuestionId" />
    </resultMap>

    <select id="selectQuestionByPage" resultMap="questionMap">

        select qs.*,
        qa.id qa_id,
        qa.id,
        qa.keywords,
        qa.create_time qa_create_time,
        qa.update_time qa_update_time,
        qa.is_deleted qa_is_deleted
        from questions qs join question_answers qa on qs.id=qa.question_id
        WHERE qa.is_deleted=0 and qs.is_deleted=0
        <if test="queryVo.type != null and queryVo.type != ''">
            and qs.type = #{queryVo.type}
        </if>
        <if test="queryVo.difficulty != null and queryVo.difficulty != ''">
            and qs.difficulty = #{queryVo.difficulty}
        </if>
        <if test="queryVo.categoryId != null">
            and qs.category_id = #{queryVo.categoryId}
        </if>
        <if test="queryVo.keyword != null and queryVo.keyword != ''">
            and title like concat('%',#{queryVo.keyword},'%')
        </if>
        order by qs.create_time desc

    </select>
    <!--多表结果映射
        resltType=直接映射，自动映射，自动映射第一层属性
        resultMap=自定义映射，自定义映射第一层属性，嵌套映射，嵌套映射的属性需要自定义映射
    -->
    <resultMap id="questionDetailMap" type="com.atguigu.exam.entity.Question">
        <id column="id" property="id"></id>
        <association property="answer" javaType="com.atguigu.exam.entity.QuestionAnswer">
            <id column="qas_id" property="id" />
            <result column="qas_create_time" property="createTime" />
            <result column="qas_update_time" property="updateTime" />
            <result column="qas_question_id" property="questionId" />
        </association>
        <collection property="choices" ofType="com.atguigu.exam.entity.QuestionChoice" notNullColumn="qcs_id">
            <id column="qcs_id" property="id" />
            <result column="qcs_question_id" property="questionId" />
            <result column="qcs_create_time" property="createTime" />
            <result column="qcs_update_time" property="updateTime" />
        </collection>
    </resultMap>

    <select id="customQueryQuestionListByPaperId" resultMap="questionDetailMap">
        SELECT pq.score paper_score,
        qs.*,
        qas.id qas_id,
        qas.question_id qas_question_id,
        qas.answer,
        qas.keywords,
        qas.create_time qas_create_time,
        qas.update_time qas_update_time,
        qcs.id qcs_id,
        qcs.question_id qcs_question_id,
        qcs.content,
        qcs.is_correct,
        qcs.sort,
        qcs.create_time qcs_create_time,
        qcs.update_time qcs_update_time
        from paper_question pq
        join questions qs on pq.question_id=qs.id
        join question_answers qas on qas.question_id=qs.id
        left join question_choices qcs on qcs.question_id=qs.id
        and qcs.is_deleted=0
        where pq.paper_id = #{paperId} and pq.is_deleted=0
        and qs.is_deleted=0 and qas.is_deleted=0
        ORDER BY qcs.sort asc;

    </select>

</mapper>